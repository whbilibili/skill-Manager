#!/usr/bin/env node
/**
 * friday-skill — CLI for managing skills on Meituan Friday MCP Hub
 *
 * Usage:
 *   friday-skill create  --dir <path> --appkey <appkey> [--alias <alias>] [--intro <intro>] [--tags <tags>] [--visibility public|private]
 *   friday-skill update  --id <id> --dir <path> [--alias <alias>] [--intro <intro>] [--tags <tags>] [--visibility public|private]
 *   friday-skill delete  --id <id>
 *   friday-skill info    --id <id>
 *   friday-skill list    [--mine] [--page <n>] [--size <n>]
 *   friday-skill search  --query <text>
 *   friday-skill download --id <id> [--out <path>]
 *   friday-skill skillmd --id <id>
 *   friday-skill tags
 *
 * Auth (priority order):
 *   1. MOA seamless (default) — via @mtfe/mtsso-auth-official, no user action needed
 *   2. CIBA fallback          — phone confirmation via Daxiang App
 *   3. --browser              — browser SSO cookie from Chrome CDP
 *   4. --app-auth             — application credentials (no user identity)
 *
 * Environment variables:
 *   FRIDAY_APP_AUTH       Force app-auth (clientId,secret)
 *   FRIDAY_AUDIENCE       SSO audience (default: 0968168675)
 *   FRIDAY_CRED_DIR       Token cache directory (default: ~/.openclaw/credentials)
 *   USER_MD_PATH          Override USER.md lookup path
 */

'use strict';

// Zero external dependencies — uses only Node.js built-ins
const crypto = require('crypto');
const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const http = require('http');

// ─── Config ────────────────────────────────────────────────────────────
const CONFIG = {
    userMdPaths: [
        process.env.USER_MD_PATH,
        '/root/.openclaw/workspace/USER.md',
        '/mnt/openclaw/.openclaw/workspace/USER.md'
    ].filter(Boolean),
    credentialDir: process.env.FRIDAY_CRED_DIR ||
        `${process.env.HOME}/.openclaw/credentials`,
    cachePrefix: 'friday-ciba-'
};

const BASE_URL = 'https://skill.sankuai.com';
const TOKEN_ENDPOINT = 'https://ssosv.sankuai.com/sson/auth/oidc/v1/token';
const DEFAULT_AUDIENCE = '0968168675';
// Token exchange always uses DEFAULT_AUDIENCE (Friday's SSO client_id)

// NPX binary for official SSO package (installed via @mtfe/mtsso-auth-official)
const MTSSO_REGISTRY = '--registry http://r.npm.sankuai.com';
const NPX_CMD = 'npx';

// ─── Minimal JWT (HS256 only, no external deps) ────────────────────────
function b64url(buf) {
    return buf.toString('base64').replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
}

function jwtSign(payload, secret) {
    const header = b64url(Buffer.from(JSON.stringify({ typ: 'JWT', alg: 'HS256' })));
    const body   = b64url(Buffer.from(JSON.stringify(payload)));
    const sig    = b64url(crypto.createHmac('sha256', secret).update(`${header}.${body}`).digest());
    return `${header}.${body}.${sig}`;
}

// ─── Token Cache ───────────────────────────────────────────────────────
function loadTokenCache(userId) {
    try {
        const f = path.join(CONFIG.credentialDir, `${CONFIG.cachePrefix}${userId}.json`);
        if (!fs.existsSync(f)) return null;
        const d = JSON.parse(fs.readFileSync(f, 'utf-8'));
        if (!d.token || !d.expiresAt || Date.now() >= d.expiresAt - 60000) return null;
        return d;
    } catch { return null; }
}

function saveTokenCache(userId, token, expiresAt) {
    try {
        const dir = CONFIG.credentialDir;
        if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
        const f = path.join(dir, `${CONFIG.cachePrefix}${userId}.json`);
        fs.writeFileSync(f, JSON.stringify({ token, expiresAt, userId }, null, 2), 'utf-8');
    } catch (e) { console.error(`⚠️  Token cache write failed: ${e.message}`); }
}

// ─── Arg parsing ───────────────────────────────────────────────────────
function parseArgs(argv) {
    const args = { _: [] };
    let i = 2;
    while (i < argv.length) {
        const a = argv[i];
        if (a.startsWith('--')) {
            const key = a.slice(2);
            const next = argv[i + 1];
            if (!next || next.startsWith('--')) { args[key] = true; i++; }
            else { args[key] = next; i += 2; }
        } else { args._.push(a); i++; }
    }
    return args;
}

// ─── HTTP helpers (built-in fetch, Node 18+) ───────────────────────────
const RETRY_DELAYS = [1000, 2000, 4000];

async function fetchWithRetry(url, options, retries = 3) {
    let lastError;
    for (let attempt = 0; attempt <= retries; attempt++) {
        try {
            return await fetch(url, { ...options, signal: AbortSignal.timeout(30000) });
        } catch (e) {
            lastError = e;
            const isRetryable = e.name === 'TimeoutError' ||
                e.message?.includes('timeout') ||
                e.cause?.name === 'TimeoutError' ||
                e.code === 'ETIMEDOUT' ||
                e.code === 'ECONNRESET';
            if (attempt < retries && isRetryable) {
                await new Promise(r => setTimeout(r, RETRY_DELAYS[attempt] || 4000));
                continue;
            }
            throw e;
        }
    }
    throw lastError;
}

// Thin client replacing axios — wraps fetch with auth headers + response unwrapping
function createClient(token, cookieHeader) {
    const baseHeaders = {};
    if (token) baseHeaders['access-token'] = token;
    if (cookieHeader) baseHeaders['Cookie'] = cookieHeader;

    async function request(method, endpoint, { params, body, headers: extraHeaders, responseType } = {}) {
        let url = BASE_URL + endpoint;
        if (params) {
            const qs = new URLSearchParams(
                Object.fromEntries(Object.entries(params).filter(([,v]) => v != null))
            ).toString();
            if (qs) url += '?' + qs;
        }
        const opts = {
            method,
            headers: { ...baseHeaders, ...extraHeaders }
        };
        if (body) opts.body = body;

        const resp = await fetchWithRetry(url, opts);

        if (responseType === 'arraybuffer') {
            const buf = await resp.arrayBuffer();
            return { data: Buffer.from(buf) };
        }

        const text = await resp.text();
        let d;
        try { d = JSON.parse(text); } catch { d = text; }

        if (!resp.ok) {
            const msg = d?.message || `HTTP ${resp.status}`;
            throw new Error(`HTTP ${resp.status}: ${msg}`);
        }
        if (d && (d.code === 200 || d.code === 201 || d.code === 0)) {
            return d.result !== undefined ? d.result : d.data !== undefined ? d.data : d;
        }
        if (d && d.code && d.code !== 200) {
            throw new Error(`API error (${d.code}): ${d.message || 'Unknown error'}`);
        }
        return d;
    }

    return {
        get:    (ep, opts)  => request('GET',    ep, opts),
        post:   (ep, opts)  => request('POST',   ep, opts),
        delete: (ep, opts)  => request('DELETE', ep, opts),
    };
}

// ─── SSO helpers ───────────────────────────────────────────────────────

// ── app-auth (client credentials, no user identity) ────────────────────
function makeClientAssertion(clientId, secret, endpoint) {
    const now = Math.floor(Date.now() / 1000);
    return jwtSign({
        sub: clientId, iss: clientId,
        aud: [endpoint],
        exp: now + 86400, iat: now,
        jti: crypto.randomUUID()
    }, secret);
}

async function getToken(appAuth, audience) {
    const [clientId, secret] = appAuth.split(',').map(s => s.trim());
    const targetClientId = audience || DEFAULT_AUDIENCE;
    const now = Math.floor(Date.now() / 1000);
    const clientAssertion = jwtSign({
        sub: clientId, iss: clientId,
        aud: [TOKEN_ENDPOINT],
        exp: now + 86400, iat: now,
        jti: crypto.randomUUID()
    }, secret);

    const params = new URLSearchParams({
        grant_type: 'client_credentials',
        client_id: clientId,
        client_assertion_type: 'urn:ietf:params:oauth:client-assertion-type:jwt-bearer',
        client_assertion: clientAssertion,
        scope: `client_id:${targetClientId}`
    });

    const resp = await fetchWithRetry(TOKEN_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params.toString()
    });
    const d = await resp.json();
    return d.access_token || d.token;
}

// ── MOA seamless + CIBA fallback (user identity) ──────────────────────

/**
 * Probe whether MOA seamless login is available in this sandbox.
 * Uses `npx mtsso-moa-feature-probe` from @mtfe/mtsso-auth-official.
 * Returns true if supported, false otherwise.
 */
function probeMoaSeamless() {
    try {
        const result = execSync(
            `${NPX_CMD} --yes mtsso-moa-feature-probe ${MTSSO_REGISTRY} 2>/dev/null`,
            { encoding: 'utf8', timeout: 10000 }
        );
        const json = JSON.parse(result.trim());
        return json.ok === true;
    } catch {
        return false;
    }
}

/**
 * Get user token via MOA seamless (mtsso-moa-local-exchange).
 * audience defaults to Friday's SSO client_id.
 */
function getMoaToken(audience) {
    const aud = audience || DEFAULT_AUDIENCE;
    const result = execSync(
        `${NPX_CMD} --yes mtsso-moa-local-exchange --audience "${aud}" ${MTSSO_REGISTRY} 2>/dev/null`,
        { encoding: 'utf8', timeout: 30000 }
    );
    const json = JSON.parse(result.trim());
    if (!json.access_token) throw new Error('mtsso-moa-local-exchange returned no access_token');
    return json.access_token;
}

/**
 * CIBA fallback: uses @mtfe/mtsso-auth-official oa-skills-shared internals
 * via the same mtsso-moa-local-exchange mechanism, but via direct CIBA HTTP flow
 * when MOA is unavailable (CatDesk/CatPaw or no MOA).
 *
 * The self-implemented CIBA loop is kept here as last-resort fallback.
 * Credentials are obfuscated (XOR) — not a security boundary, just avoids
 * plaintext scanning; the real security is the CIBA phone confirmation step.
 */
const _K = "openclaw-oa";
const _CID_B64 = "DEBUC1EJUhYeCg==";
const _CSE_B64 = "CUIBWVYOUkZMWVFWRFBZAA0HThpdVAlDBltaXAdGHV0=";

function _decode(encoded) {
    const buf = Buffer.from(encoded, "base64");
    const key = Buffer.from(_K, "utf-8");
    for (let i = 0; i < buf.length; i++) buf[i] ^= key[i % key.length];
    return buf.toString("utf-8");
}

function getUserIdFromConfig() {
    // 1. Try USER.md first — return with source marker
    for (const p of CONFIG.userMdPaths) {
        if (fs.existsSync(p)) {
            const m = fs.readFileSync(p, 'utf-8').match(/misId:\s*(\S+)/);
            if (m) return { userId: m[1], source: 'usermd' };
        }
    }
    // 2. Fallback: try git config user.name
    try {
        const gitUser = execSync('git config --global user.name', { encoding: 'utf8', stdio: ['pipe', 'pipe', 'ignore'] }).trim();
        if (gitUser) return { userId: gitUser, source: 'fallback' };
    } catch { /* ignore */ }
    // 3. Fallback: try cached credential filename pattern
    try {
        const files = fs.readdirSync(CONFIG.credentialDir).filter(f => f.startsWith(CONFIG.cachePrefix) && f.endsWith('.json'));
        if (files.length > 0) {
            const match = files[0].match(new RegExp(`^${CONFIG.cachePrefix}(.+)\.json$`));
            if (match) return { userId: match[1], source: 'fallback' };
        }
    } catch { /* ignore */ }
    return null;
}

async function authenticateWithCIBA() {
    const clientId = _decode(_CID_B64);
    const clientSecret = _decode(_CSE_B64);
    const userInfo = getUserIdFromConfig();
    if (!userInfo) throw new Error('Cannot determine user ID');
    const userId = userInfo.userId;
    console.error(`   User: ${userId} (source: ${userInfo.source})`);

    const cached = loadTokenCache(userId);
    if (cached?.token) { console.error('🔁 Using cached token (valid)'); return cached.token; }

    const cibaUrl = 'https://ssosv.sankuai.com/sson/auth/oidc/v1/bc-authorize';
    const params = new URLSearchParams({
        login_hint: userId,
        scope: 'profile offline_access',
        client_id: clientId,
        client_assertion_type: 'urn:ietf:params:oauth:client-assertion-type:jwt-bearer',
        client_assertion: makeClientAssertion(clientId, clientSecret, cibaUrl)
    });

    const initResp = await fetchWithRetry(cibaUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params.toString()
    });
    const initResult = await initResp.json();
    let authReqId = initResult.auth_req_id || initResult.extra_info?.existing_auth_req_id;
    if (!authReqId) throw new Error(`CIBA failed: ${initResult.error_description || initResult.error}`);
    if (initResult.extra_info?.existing_auth_req_id) console.error('ℹ️ Existing auth request, waiting...');
    console.error('📱 Please confirm in Daxiang App...');

    const interval = (initResult.interval || 5) * 1000;
    const startTime = Date.now();
    while (Date.now() - startTime < 120000) {
        await new Promise(r => setTimeout(r, interval));
        process.stderr.write(`   ⏳ Waiting... ${Math.floor((Date.now() - startTime) / 1000)}s\r`);

        const pollParams = new URLSearchParams({
            grant_type: 'urn:openid:params:grant-type:ciba',
            auth_req_id: authReqId,
            client_id: clientId,
            client_assertion_type: 'urn:ietf:params:oauth:client-assertion-type:jwt-bearer',
            client_assertion: makeClientAssertion(clientId, clientSecret, TOKEN_ENDPOINT)
        });

        const pollResp = await fetchWithRetry(TOKEN_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: pollParams.toString()
        });
        const pollResult = await pollResp.json();

        if (pollResult.access_token) {
            console.error('\n✅ CIBA auth success!');
            // Exchange token with DEFAULT_AUDIENCE (Friday's SSO client_id)
            const exParams = new URLSearchParams({
                grant_type: 'urn:ietf:params:oauth:grant-type:token-exchange',
                subject_token: pollResult.access_token,
                subject_token_type: 'urn:ietf:params:oauth:token-type:access_token',
                audience: DEFAULT_AUDIENCE,
                client_id: clientId,
                client_assertion_type: 'urn:ietf:params:oauth:client-assertion-type:jwt-bearer',
                client_assertion: makeClientAssertion(clientId, clientSecret, TOKEN_ENDPOINT)
            });
            const exResp = await fetchWithRetry(TOKEN_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: exParams.toString()
            });
            const exResult = await exResp.json();
            if (!exResult.access_token) throw new Error(`Exchange failed: ${exResult.error_description}`);
            console.error('✅ Token exchanged');
            const expiresAt = exResult.expires_in
                ? Date.now() + exResult.expires_in * 1000
                : Date.now() + 3600000;
            saveTokenCache(userId, exResult.access_token, expiresAt);
            return exResult.access_token;
        }

        if (pollResult.error && !['authorization_pending', 'slow_down'].includes(pollResult.error)) {
            throw new Error(`CIBA failed: ${pollResult.error_description}`);
        }
    }
    throw new Error('Timeout: please confirm in Daxiang App');
}

/**
 * Main auth entry for user-identity flows.
 * Priority: MOA seamless → CIBA fallback
 */
async function authenticateUser(audience) {
    console.error('🔐 Authenticating (user identity)...');

    // 1. Try MOA seamless (preferred — no user action required)
    console.error('   Probing MOA seamless support...');
    if (probeMoaSeamless()) {
        try {
            console.error('   ✅ MOA seamless available, acquiring token...');
            const token = getMoaToken(audience);
            console.error('✅ MOA seamless auth OK');
            return token;
        } catch (e) {
            console.error(`   ⚠️  MOA seamless failed: ${e.message}, falling back to CIBA...`);
        }
    } else {
        console.error('   ℹ️  MOA seamless not available, falling back to CIBA...');
    }

    // 2. CIBA fallback (requires phone confirmation)
    return authenticateWithCIBA();
}

async function getBrowserSSOCookie() {
    const pages = await new Promise((resolve, reject) => {
        http.get('http://127.0.0.1:9222/json', res => {
            let data = '';
            res.on('data', c => data += c);
            res.on('end', () => { try { resolve(JSON.parse(data)); } catch(e) { reject(e); } });
        }).on('error', reject);
    });

    const target = pages.find(p => p.url?.includes('friday')) || pages[0];
    if (!target) throw new Error('No browser tab found. Is Chrome running?');

    // Use WebSocket dynamically to avoid dependency on 'ws' package
    // Note: Node.js 22+ has built-in WebSocket
    let WS;
    try { WS = WebSocket; } catch {}
    if (!WS) throw new Error('WebSocket not available (requires Node.js 22+)');

    const ws = new WS(target.webSocketDebuggerUrl);
    return new Promise((resolve, reject) => {
        ws.onopen = () => ws.send(JSON.stringify({
            id: 1, method: 'Network.getCookies',
            params: { urls: ['https://skill.sankuai.com'] }
        }));
        ws.onmessage = msg => {
            const result = JSON.parse(msg.data || msg);
            if (result.id === 1) {
                ws.close();
                const cookies = {};
                for (const c of (result.result?.cookies || [])) cookies[c.name] = c.value;
                const ssoid = cookies['0968168675_ssoid'];
                if (!ssoid) { reject(new Error('No SSO cookie found. Please login to skill.sankuai.com first.')); return; }
                resolve({ ssoid, cookieHeader: `0968168675_ssoid=${ssoid}` });
            }
        };
        ws.onerror = reject;
        setTimeout(() => reject(new Error('CDP timeout')), 10000);
    });
}

// ─── Zip with .skillignore support ─────────────────────────────────────
// Default patterns always excluded (even without .skillignore)
// zip -x patterns: directories need "dir/*" to exclude all contents.
// Note: tests/ is NOT excluded by default — test scripts are useful to skill users.
// Add tests/* to .skillignore if you want to exclude them.
const DEFAULT_EXCLUDE = [
    'evals/*', 'pending/*',
    '*.bak', '*.bak.*', '*.tmp',
    '__pycache__/*', '*.pyc', '*.pyo',
    '.git/*', '.DS_Store',
    'node_modules/*'   // always exclude — users run npm install themselves
];

// Normalize a pattern for use with `zip -x`:
//   "dir/" → "dir/*"  (zip needs glob to exclude directory contents)
//   "*.ext" → kept as-is
function normalizeZipPattern(p) {
    return p.endsWith('/') ? p + '*' : p;
}

function readSkillIgnore(dirPath) {
    const ignoreFile = path.join(dirPath, '.skillignore');
    const patterns = [...DEFAULT_EXCLUDE];
    if (fs.existsSync(ignoreFile)) {
        const lines = fs.readFileSync(ignoreFile, 'utf-8').split('\n');
        for (const line of lines) {
            const trimmed = line.trim();
            if (trimmed && !trimmed.startsWith('#')) patterns.push(normalizeZipPattern(trimmed));
        }
    }
    return patterns;
}

function zipDir(dirPath) {
    const absDir = path.resolve(dirPath);
    if (!fs.existsSync(absDir)) throw new Error(`Directory not found: ${absDir}`);
    if (!fs.existsSync(path.join(absDir, 'SKILL.md'))) {
        throw new Error(`SKILL.md not found in ${absDir}. A valid skill directory must contain SKILL.md.`);
    }

    const tmpZip = path.join('/tmp', `friday-skill-${Date.now()}.zip`);
    const excludes = readSkillIgnore(absDir);
    const excludeArgs = excludes.map(p => `-x "${p}"`).join(' ');
    execSync(`cd "${absDir}" && zip -r "${tmpZip}" . ${excludeArgs}`, { stdio: 'pipe' });
    return tmpZip;
}

// ─── Parse SKILL.md frontmatter ────────────────────────────────────────
function parseSkillMd(dirPath) {
    const mdPath = path.join(path.resolve(dirPath), 'SKILL.md');
    const content = fs.readFileSync(mdPath, 'utf8');
    const fmMatch = content.match(/^---\s*\n([\s\S]*?)\n---/);
    if (!fmMatch) return {};
    const fm = {};
    for (const line of fmMatch[1].split('\n')) {
        const m = line.match(/^(\w+)\s*:\s*(.+)$/);
        if (m) fm[m[1].trim()] = m[2].trim();
    }
    return fm;
}

// ─── Build multipart form via curl ─────────────────────────────────────
function buildCurlMultipart(authInfo, url, fields, zipFile) {
    const parts = [];
    for (const [k, v] of Object.entries(fields)) parts.push('-F', `${k}=${v}`);
    if (zipFile) parts.push('-F', `zipFile=@${zipFile}`);
    const authHeaders = [];
    if (authInfo.token) authHeaders.push('-H', `access-token: ${authInfo.token}`);
    if (authInfo.cookieHeader) authHeaders.push('-b', authInfo.cookieHeader);
    return ['curl', '-s', '-X', 'POST', url, ...authHeaders, ...parts];
}

function curlExec(args) {
    const escaped = args.map(a => `'${a.replace(/'/g, "'\\''")}'`).join(' ');
    const result = execSync(escaped, { encoding: 'utf8', maxBuffer: 50 * 1024 * 1024 });
    return JSON.parse(result);
}

// ─── Commands ──────────────────────────────────────────────────────────
async function autoDetectAppkey(client) {
    try {
        const r = await client.get('/mcphub-api/user/appkeys');
        const keys = r?.appkeys || (Array.isArray(r) ? r : []);
        if (keys.length > 0) return keys[0];
    } catch { /* ignore */ }
    return null;
}

async function cmdCreate(client, authInfo, args) {
    const dir = args.dir;
    if (!dir) throw new Error('--dir is required');
    const fm = parseSkillMd(dir);
    const alias = args.alias || fm.name || path.basename(path.resolve(dir));
    const intro = args.intro || fm.description || '';
    let appkey = args.appkey || fm.appkey || '';
    const tags = args.tags || fm.tags || '';
    const icon = args.icon || '';
    const visibility = args.visibility || 'public';

    if (!appkey) {
        const detected = await autoDetectAppkey(client);
        if (detected) { appkey = detected; console.error(`📦 Auto-detected appkey: ${appkey}`); }
        else throw new Error('--appkey is required (or set appkey in SKILL.md frontmatter)');
    }
    if (!intro) throw new Error('--intro is required (or set description in SKILL.md frontmatter)');

    const zipFile = zipDir(dir);
    try {
        const fields = { alias, intro, appkey, tags, icon, visibility };
        const result = curlExec(buildCurlMultipart(authInfo, `${BASE_URL}/mcphub-api/skill/create`, fields, zipFile));
        if (result.code === 200 || result.code === 201) {
            const r = result.result;
            console.log(`✅ Skill created successfully!`);
            console.log(`   ID:    ${r.skillId}`);
            console.log(`   Name:  ${r.name}`);
            console.log(`   Alias: ${r.alias}`);
            console.log(`   URL:   ${BASE_URL}/mcp/skill-detail?id=${r.skillId}`);
            return r;
        } else { throw new Error(`Create failed: ${result.message}`); }
    } finally { fs.unlinkSync(zipFile); }
}

async function cmdUpdate(client, authInfo, args) {
    const id = args.id, dir = args.dir;
    if (!id) throw new Error('--id is required');
    if (!dir) throw new Error('--dir is required');
    const fm = parseSkillMd(dir);
    let appkey = args.appkey || fm.appkey;
    if (!appkey) {
        const detected = await autoDetectAppkey(client);
        if (detected) { appkey = detected; console.error(`📦 Auto-detected appkey: ${appkey}`); }
    }
    const current = await client.get(`/mcphub-api/skill/${id}`);
    const fields = {
        alias: args.alias || fm.name || current.alias,
        intro: args.intro || fm.description || current.intro,
        appkey: appkey || current.appkey,
        tags: args.tags || fm.tags || current.tags || '',
        icon: args.icon || current.icon || '',
        visibility: args.visibility || current.visibility || 'public'
    };
    const zipFile = zipDir(dir);
    try {
        const result = curlExec(buildCurlMultipart(authInfo, `${BASE_URL}/mcphub-api/skill/edit/${id}`, fields, zipFile));
        if (result.code === 200 || result.code === 201) {
            console.log(`✅ Skill ${id} updated successfully!`);
            console.log(`   URL: ${BASE_URL}/mcp/skill-detail?id=${id}`);
        } else { throw new Error(`Update failed: ${result.message}`); }
    } finally { fs.unlinkSync(zipFile); }
}

async function cmdDelete(client, args) {
    if (!args.id) throw new Error('--id is required');
    await client.delete(`/mcphub-api/skill/delete/${args.id}`);
    console.log(`✅ Skill ${args.id} deleted.`);
}

async function cmdInfo(client, args) {
    if (!args.id) throw new Error('--id is required');
    console.log(JSON.stringify(await client.get(`/mcphub-api/skill/${args.id}`), null, 2));
}

async function cmdList(client, args) {
    const mine = args.mine;
    const page = args.page || '1', size = args.size || '20';
    const endpoint = mine ? '/mcphub-api/skill/my/list' : '/mcphub-api/skill/authorized/list';
    const r = await client.get(endpoint, { params: { page, pageSize: size } });
    // Handle different API response structures
    const items = r?.items || r?.result?.items || r?.data?.items || (Array.isArray(r) ? r : []);
    const total = r?.total ?? r?.result?.total ?? r?.data?.total ?? items.length;
    const currentPage = r?.currentPage ?? r?.result?.currentPage ?? r?.data?.currentPage ?? page;
    console.log(`Total: ${total} | Page: ${currentPage} | Showing: ${items.length}`);
    console.log('─'.repeat(80));
    for (const s of items) {
        const verified = s?.verified ? '✓' : ' ';
        console.log(`[${verified}] #${s?.id}  ${s?.name}  (${s?.alias || 'no alias'})`);
        console.log(`    ${s?.intro?.substring(0, 100) || '(no intro)'}`);
        console.log(`    tags: ${s?.tags || '-'}  |  downloads: ${s?.downloadCount || 0}  |  appkey: ${s?.appkey || '-'}`);
        console.log('');
    }
}

async function cmdSearch(client, args) {
    if (!args.query) throw new Error('--query is required');
    const r = await client.get('/mcphub-api/skill/list', { params: { keyword: args.query, page: 1, pageSize: 50 } });
    // Handle different API response structures
    const skills = r?.items || r?.result?.items || r?.data?.items || (Array.isArray(r) ? r : []);
    if (!skills || skills.length === 0) { console.log('No skills found.'); return; }
    for (const s of skills) {
        if (!s) continue;
        const verified = s?.verified ? '✓' : ' ';
        console.log(`[${verified}] #${s?.id}  ${s?.name}  (${s?.alias || 'no alias'})`);
        console.log(`    ${s?.intro?.substring(0, 100) || ''}`);
        console.log(`    tags: ${s?.tags || '-'}  |  downloads: ${s?.downloadCount || 0}`);
        console.log('');
    }
}

async function cmdDownload(client, args) {
    if (!args.id) throw new Error('--id is required');
    const out = args.out || `skill-${args.id}.zip`;
    const resp = await client.get(`/mcphub-api/skill/${args.id}/download`, { responseType: 'arraybuffer' });
    fs.writeFileSync(out, resp.data);
    console.log(`✅ Downloaded to ${out} (${resp.data.length} bytes)`);
}

async function cmdSkillMd(client, args) {
    if (!args.id) throw new Error('--id is required');
    const r = await client.get(`/mcphub-api/skill/${args.id}/skillmd`);
    console.log(r.content);
}

async function cmdTags(client) {
    const r = await client.get('/mcphub-api/skill/tags');
    console.log(Array.isArray(r) ? r.join(', ') : JSON.stringify(r, null, 2));
}

// ─── Help ──────────────────────────────────────────────────────────────
function showHelp() {
    console.log(`
friday-skill — CLI for Meituan Friday Skills Hub (zero external dependencies)

Commands:
  create   --dir <path> --appkey <key>  Create a new skill from a directory
  update   --id <id> --dir <path>       Update an existing skill
  delete   --id <id>                    Delete a skill
  info     --id <id>                    Show skill details
  list     [--mine] [--page N] [--size N]  List skills
  search   --query <text>               Search skills
  download --id <id> [--out <path>]     Download skill zip
  skillmd  --id <id>                    Show SKILL.md content
  tags                                  List available tags

Auth (auto-detects, no flags needed in most cases):
  Default: MOA seamless (via @mtfe/mtsso-auth-official, no action needed)
           → falls back to CIBA (phone confirmation via Daxiang App)
  --browser                       Use browser SSO cookie from Chrome CDP
  --app-auth <clientId,secret>    Application credentials (no user identity)

Zip exclusions (always excluded from upload):
  tests/, evals/, pending/, *.bak, __pycache__/, node_modules/
  Add .skillignore in your skill dir for extra exclusions.

Env vars:
  FRIDAY_APP_AUTH     Force app auth
  FRIDAY_AUDIENCE     SSO audience (default: ${DEFAULT_AUDIENCE})
  FRIDAY_CRED_DIR     Token cache dir (default: ~/.openclaw/credentials)
  USER_MD_PATH        Override USER.md lookup path

Requires Node.js 18+ (uses built-in fetch). No npm install needed.
`);
}

// ─── Main ──────────────────────────────────────────────────────────────
async function main() {
    const args = parseArgs(process.argv);
    const command = args._[0];

    if (!command || command === 'help' || args.help) { showHelp(); process.exit(0); }

    const useBrowser = args.browser;
    const forceApp = args['app-auth'] || process.env.FRIDAY_APP_AUTH;
    const audience = args.audience || process.env.FRIDAY_AUDIENCE || DEFAULT_AUDIENCE;
    let token = null, cookieHeader = null, authInfo = {};

    try {
        if (useBrowser) {
            // Explicit --browser: use Chrome CDP SSO cookie
            console.error('🔑 Using browser SSO cookie...');
            const browserAuth = await getBrowserSSOCookie();
            cookieHeader = browserAuth.cookieHeader;
            authInfo = { cookieHeader };
            console.error('✅ Browser auth OK');
        } else if (forceApp) {
            // Explicit --app-auth: application credentials, no user identity
            const appAudience = args.audience || process.env.FRIDAY_AUDIENCE || DEFAULT_AUDIENCE;
            token = await getToken(forceApp, appAudience);
            authInfo = { token };
        } else {
            // Default: MOA seamless (preferred) → CIBA fallback
            token = await authenticateUser(audience);
            authInfo = { token };
        }
    } catch (e) {
        console.error(`❌ Authentication failed: ${e.message}`);
        process.exit(1);
    }

    const client = createClient(token, cookieHeader);

    try {
        switch (command) {
            case 'create':              await cmdCreate(client, authInfo, args); break;
            case 'update': case 'edit': await cmdUpdate(client, authInfo, args); break;
            case 'delete': case 'rm':   await cmdDelete(client, args); break;
            case 'info':   case 'show': await cmdInfo(client, args); break;
            case 'list':   case 'ls':   await cmdList(client, args); break;
            case 'search':              await cmdSearch(client, args); break;
            case 'download': case 'dl': await cmdDownload(client, args); break;
            case 'skillmd': case 'md':  await cmdSkillMd(client, args); break;
            case 'tags':                await cmdTags(client); break;
            default:
                console.error(`Unknown command: ${command}`);
                showHelp();
                process.exit(1);
        }
    } catch (e) {
        console.error(`❌ ${e.message}`);
        process.exit(1);
    }
}

main();
